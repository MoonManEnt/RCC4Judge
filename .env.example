# Anedot (active donation processor)
# From Anedot dashboard → Settings → Integrations → [your webhook] → "Get secret token".
# HMAC-SHA256 of the raw request body, hex-encoded, sent in the `x-request-signature` header.
ANEDOT_WEBHOOK_SECRET=

# Authorize.net (LEGACY — being decommissioned with Anedot cutover; keep until cleanup commit)
AUTHORIZENET_API_LOGIN_ID=
AUTHORIZENET_TRANSACTION_KEY=
AUTHORIZENET_SANDBOX=false
AUTHORIZENET_SIGNATURE_KEY=

# Upstash Redis (KV) — donor records + idempotency keys
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=re_...

# Campaign email routing
# Comma-separated list — donor confirmation alerts go here. Treasurer must be the
# first entry whose local part starts with "treasurer@" so the 48-hour alerter
# can find it.
CAMPAIGN_DONATION_NOTIFY_EMAILS=Treasurer@RCC4Judge.com
CAMPAIGN_ENDORSEMENT_EMAIL=Chairman@RCC4Judge.com
CAMPAIGN_FROM_DONATE=donate@rcc4judge.com
CAMPAIGN_FROM_SUPPORT=support@rcc4judge.com
CAMPAIGN_REPLY_TO=Treasurer@RCC4Judge.com

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.rcc4judge.com
