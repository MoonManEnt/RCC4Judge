# Authorize.net (PNC merchant account)
AUTHORIZENET_API_LOGIN_ID=
AUTHORIZENET_TRANSACTION_KEY=
AUTHORIZENET_SANDBOX=false
# From Authorize.net merchant portal → Account → Webhooks → Signature Key
AUTHORIZENET_SIGNATURE_KEY=
# Configure Authorize.net to POST webhooks to: https://www.rcc4judge.com/api/webhooks/stripe

# Upstash Redis (KV)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=re_...

# Campaign email routing
CAMPAIGN_DONATION_NOTIFY_EMAILS=Treasurer@RCC4Judge.com,Support@RCC4Judge.com
CAMPAIGN_SUPPORT_EMAIL=Support@RCC4Judge.com
CAMPAIGN_ENDORSEMENT_EMAIL=Chairman@RCC4Judge.com
CAMPAIGN_FROM_DONATE=donate@rcc4judge.com
CAMPAIGN_FROM_SUPPORT=support@rcc4judge.com
CAMPAIGN_REPLY_TO=Support@RCC4Judge.com

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.rcc4judge.com
